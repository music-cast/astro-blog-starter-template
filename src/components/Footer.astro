---
import { SITE_TITLE } from '../consts';

const today = new Date();
const LOGIN_URL = 'https://app.musicca.st/login';
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<span class="brand-name">{SITE_TITLE}</span>
			<p>White-label distribution infrastructure for music distributors.</p>
		</div>
		<div class="footer-links">
			<a href="/#features">Features</a>
			<a href="/about">About</a>
			<a href={LOGIN_URL}>Sign in</a>
		</div>
	</div>
	<div class="footer-bottom">&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.</div>
</footer>
<style>
	footer {
		padding: 3em 1.25em 2em 1.25em;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}
	.footer-inner {
		width: 1120px;
		max-width: 100%;
		margin: auto;
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 2em;
	}
	.brand-name {
		font-weight: 700;
		font-size: 1.1em;
		color: rgb(255, 255, 255);
	}
	.footer-brand p {
		max-width: 260px;
		margin-top: 0.5em;
	}
	.footer-links {
		display: flex;
		gap: 1.5em;
		align-items: flex-start;
	}
	.footer-links a {
		color: rgb(160, 160, 170);
		text-decoration: none;
	}
	.footer-links a:hover {
		color: #ff00ff;
	}
	.footer-bottom {
		width: 1120px;
		max-width: 100%;
		margin: 2.5em auto 0 auto;
		padding-top: 1.5em;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		color: rgb(120, 120, 130);
		font-size: 0.85em;
	}
</style>
