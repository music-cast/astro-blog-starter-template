---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';

const LOGIN_URL = 'https://app.musicca.st/login';
---

<header>
	<nav>
		<a class="brand" href="/">
			<svg viewBox="0 0 128 128" width="28" height="28" aria-hidden="true">
				<rect width="128" height="128" rx="28" fill="#060608" />
				<rect x="30" y="66" width="14" height="32" rx="4" fill="#ff00ff" />
				<rect x="57" y="42" width="14" height="56" rx="4" fill="#ff00ff" />
				<rect x="84" y="54" width="14" height="44" rx="4" fill="#ff00ff" />
			</svg>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/#features">Features</HeaderLink>
			<HeaderLink href="/#how-it-works">How it works</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="cta-links">
			<a class="btn btn-primary btn-small" href={LOGIN_URL}>Sign in</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.25em;
		background: rgba(6, 6, 8, 0.85);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
		position: sticky;
		top: 0;
		z-index: 50;
	}
	nav {
		width: 1120px;
		max-width: 100%;
		margin: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.6em;
		font-weight: 700;
		font-size: 1.15em;
		color: rgb(255, 255, 255);
		text-decoration: none;
		padding: 1em 0;
	}
	.internal-links {
		display: flex;
		align-items: center;
	}
	.internal-links a {
		padding: 1.4em 0.9em;
		color: rgb(200, 200, 210);
		text-decoration: none;
		font-size: 0.95em;
	}
	.internal-links a:hover,
	.internal-links a.active {
		color: rgb(255, 255, 255);
	}
	.btn-small {
		padding: 0.6em 1.3em;
		font-size: 0.9em;
	}
	@media (max-width: 720px) {
		.internal-links {
			display: none;
		}
	}
</style>
