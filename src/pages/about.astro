---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const title = `About — ${SITE_TITLE}`;
const description =
	'MusicCast is white-label distribution infrastructure for music distributors: one workspace for catalog, QC, and real DDEX delivery.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<section class="section intro">
				<span class="eyebrow">About</span>
				<h1>Distribution, run like software — not spreadsheets</h1>
				<p class="lede">
					Distributors have long stitched together spreadsheets, shared drives, and one-off
					delivery scripts to move music from a label's hard drive onto DSPs. MusicCast replaces
					that with a single platform: catalog, quality control, and delivery, all in one place.
				</p>
			</section>

			<section class="section">
				<h2>Built for the way distribution actually works</h2>
				<div class="prose">
					<p>
						A distributor isn't one team working on one catalog — it's a network of labels and
						artists, each with their own releases, their own deadlines, and their own need to see
						what's happening to their music. MusicCast is multi-tenant from the ground up: every
						distributor gets an isolated, white-labeled workspace, and can extend scoped logins to
						the labels and artists they work with, so each one manages only their own catalog.
					</p>
					<p>
						Every release moves through the same guarded path: a guided wizard that imports
						metadata and checks audio for duplicates before it's saved, a QC queue backed by
						automated AI pre-review, and — when it's approved — real DDEX delivery to your
						aggregator and direct DSPs, with UPC and ISRC codes issued automatically. Nothing is
						marked "delivered" unless it actually was.
					</p>
				</div>
			</section>

			<section class="section">
				<h2>Where it runs</h2>
				<div class="prose">
					<p>
						MusicCast runs on Cloudflare's global edge network, with an isolated database per
						distributor. That means fast page loads wherever your team and your artists are, and
						one tenant's catalog never touches another's.
					</p>
				</div>
			</section>

			<section class="section cta-banner">
				<h2>Want to see it running your catalog?</h2>
				<a class="btn btn-primary" href="https://app.musicca.st/login">Sign in to your workspace</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		padding-top: 5em;
		max-width: 760px;
	}
	.lede {
		font-size: 1.15em;
		max-width: 640px;
	}
	.prose {
		max-width: 720px;
	}
	.cta-banner {
		text-align: center;
	}
	.cta-banner .btn {
		margin-top: 1em;
	}
	@media (max-width: 600px) {
		.intro {
			padding-top: 3em;
		}
	}
</style>
